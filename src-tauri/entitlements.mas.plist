<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store Sandboxed 权限配置 -->

    <!-- 允许访问剪贴板 -->
    <key>NSAppleEventsUsageDescription</key>
    <string>贴立方需要访问剪贴板以监听和管理您的剪贴板历史记录</string>

    <!-- 允许使用本地网络 (局域网同步) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>贴立方需要访问本地网络以在局域网内同步剪贴板和传输文件</string>

    <!-- 允许使用 mDNS 服务发现 -->
    <key>NSBonjourServices</key>
    <array>
        <string>_tie-lifang._tcp</string>
    </array>

    <!-- 允许网络访问 -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- 允许文件访问 (用于保存图片和接收文件) -->
    <key>NSDocumentsFolderUsageDescription</key>
    <string>贴立方需要访问文档文件夹以保存和管理文件</string>

    <key>NSDownloadsFolderUsageDescription</key>
    <string>贴立方需要访问下载文件夹以保存接收的文件和图片</string>

    <!-- App Sandbox 配置 -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- 允许网络连接 (outbound) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- 允许网络连接 (inbound - 用于 P2P 同步) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- 允许读/写用户文件 -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- 允许读/写下载文件夹 -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- 允许读/写图片文件夹 (可选) -->
    <key>com.apple.security.assets.pictures.read-write</key>
    <true/>
</dict>
</plist>
