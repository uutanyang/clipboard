{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "贴立方-实例2",
  "version": "0.1.0",
  "identifier": "com.yangtanfang.tie-lifang.instance2",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1422",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "贴立方-实例2",
        "width": 500,
        "minWidth": 450,
        "height": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost http://127.0.0.1:* data: blob:; style-src 'self' 'unsafe-inline'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
